source "Kconfig.zephyr"

menu "AES KW sample"

config AES_KW_SAMPLE_SHOW_KWP
        bool "Demonstrate AES-KWP usage instead of AES-KW"
        default n
        help
          When activated, sample demonstrates AES-KWP (key wrap with padding)
          algorithm usage.

endmenu
